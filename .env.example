# Copy to .env and fill in at least one key. `pnpm example` loads this via dotenv.
# Get keys: https://friendli.ai  ·  https://opengateway.ai  ·  https://openrouter.ai/keys  ·  https://wafer.ai
FRIENDLI_TOKEN=
OPENGATEWAY_API_KEY=
# Live diagnostic scripts default to https://apis.opengateway.ai/v1.
# Set AI_BASE_URL only for another OpenGateway endpoint. For a proxy/custom host,
# also set OPENGATEWAY_ALLOW_CUSTOM_BASE_URL=1 so the key is sent deliberately.
# AI_BASE_URL=https://apis.opengateway.ai/v1
# OPENGATEWAY_ALLOW_CUSTOM_BASE_URL=
OPENROUTER_API_KEY=
WAFER_API_KEY=
