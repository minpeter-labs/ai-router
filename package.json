{
  "name": "@minpeter/ai-router",
  "version": "0.0.3",
  "description": "Provider-agnostic, modality-aware language model router with fallback for the Vercel AI SDK.",
  "type": "module",
  "license": "MIT",
  "author": "minpeter <minpeter@vooy.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minpeter-labs/ai-router.git"
  },
  "homepage": "https://github.com/minpeter-labs/ai-router#readme",
  "bugs": "https://github.com/minpeter-labs/ai-router/issues",
  "packageManager": "pnpm@11.3.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./friendli": {
      "types": "./dist/friendli.d.ts",
      "import": "./dist/friendli.js",
      "require": "./dist/friendli.cjs",
      "default": "./dist/friendli.js"
    },
    "./openrouter": {
      "types": "./dist/openrouter.d.ts",
      "import": "./dist/openrouter.js",
      "require": "./dist/openrouter.cjs",
      "default": "./dist/openrouter.js"
    },
    "./opengateway": {
      "types": "./dist/opengateway.d.ts",
      "import": "./dist/opengateway.js",
      "require": "./dist/opengateway.cjs",
      "default": "./dist/opengateway.js"
    },
    "./wafer": {
      "types": "./dist/wafer.d.ts",
      "import": "./dist/wafer.js",
      "require": "./dist/wafer.cjs",
      "default": "./dist/wafer.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:ci": "biome ci .",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "peerDependencies": {
    "@ai-sdk/openai-compatible": "^3.0.0-beta.36",
    "ai": "^7.0.0-beta.116"
  },
  "dependencies": {
    "@ai-sdk/provider": "^4.0.0-beta.14",
    "@ai-sdk/provider-utils": "^5.0.0-beta.30"
  },
  "devDependencies": {
    "@ai-sdk/openai-compatible": "^3.0.0-beta.36",
    "@biomejs/biome": "2.4.16",
    "@changesets/cli": "^2.27.0",
    "@types/node": "^25.9.3",
    "ai": "^7.0.0-beta.116",
    "dotenv": "^17.4.2",
    "tsup": "^8.5.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "ultracite": "^7.8.3",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai",
    "vercel-ai-sdk",
    "router",
    "fallback",
    "llm",
    "openai-compatible",
    "friendli",
    "openrouter",
    "opengateway",
    "wafer"
  ]
}
