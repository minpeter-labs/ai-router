{
  "name": "@minpeter/ai-router",
  "version": "0.0.4",
  "description": "Provider-agnostic, modality-aware language model router with fallback for the Vercel AI SDK.",
  "type": "module",
  "license": "MIT",
  "author": "minpeter <minpeter@vooy.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minpeter-labs/ai-router.git"
  },
  "homepage": "https://github.com/minpeter-labs/ai-router#readme",
  "bugs": "https://github.com/minpeter-labs/ai-router/issues",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./friendli": {
      "types": "./dist/provider/friendli/friendli.d.ts",
      "import": "./dist/friendli.js",
      "require": "./dist/friendli.cjs",
      "default": "./dist/friendli.js"
    },
    "./openrouter": {
      "types": "./dist/provider/openrouter/openrouter.d.ts",
      "import": "./dist/openrouter.js",
      "require": "./dist/openrouter.cjs",
      "default": "./dist/openrouter.js"
    },
    "./opengateway": {
      "types": "./dist/provider/opengateway/opengateway.d.ts",
      "import": "./dist/opengateway.js",
      "require": "./dist/opengateway.cjs",
      "default": "./dist/opengateway.js"
    },
    "./wafer": {
      "types": "./dist/provider/wafer/wafer.d.ts",
      "import": "./dist/wafer.js",
      "require": "./dist/wafer.cjs",
      "default": "./dist/wafer.js"
    }
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json && node scripts/fix-declaration-imports.mjs && pnpm check:package-types && pnpm check:package-runtime && pnpm check:package-artifacts",
    "check:package-artifacts": "node scripts/check-package-artifacts.mjs",
    "check:package-runtime": "node scripts/check-package-runtime.mjs",
    "check:package-types": "tsc --ignoreConfig --noEmit --strict --skipLibCheck false --module NodeNext --moduleResolution NodeNext --target ES2022 --lib ES2022,DOM,DOM.Iterable --types node test-d/package-consumer.mts test-d/json-schema.d.ts",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:ci": "biome ci .",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "peerDependencies": {
    "@ai-sdk/openai-compatible": "^3.0.1",
    "ai": "^7.0.4"
  },
  "dependencies": {
    "@ai-sdk/provider": "^4.0.0",
    "@ai-sdk/provider-utils": "^5.0.1"
  },
  "devDependencies": {
    "@ai-sdk/openai-compatible": "^3.0.1",
    "@biomejs/biome": "2.5.1",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.0.1",
    "ai": "^7.0.4",
    "dotenv": "^17.4.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^7.0.2",
    "ultracite": "^7.8.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai",
    "vercel-ai-sdk",
    "router",
    "fallback",
    "llm",
    "openai-compatible",
    "friendli",
    "openrouter",
    "opengateway",
    "wafer"
  ]
}
